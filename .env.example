# Google OAuth
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# Canva
VITE_CANVA_API_KEY=

# Supabase Storage (for images and videos)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_SUPABASE_BUCKET=nicola-assets

# NEMO Video API
VITE_NEMO_API_URL=https://mega-api-prod.nemovideo.ai
VITE_NEMO_TOKEN=

# Meta/Instagram API (for publishing and analytics)
VITE_META_APP_ID=
VITE_META_APP_SECRET=
# Page Access Token is stored in Firestore/localStorage

# Make.com
VITE_MAKE_WEBHOOK_URL=

# CapCut
VITE_CAPCUT_API_KEY=

# Optional: Error Tracking (Sentry)
# Get from https://sentry.io
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Optional: Gemini AI
# GEMINI_API_KEY=